POSTGRES_DB=vm_builder
POSTGRES_USER=vm_builder
POSTGRES_PASSWORD=vm_builder
DATABASE_URL=postgresql+psycopg://vm_builder:vm_builder@db:5432/vm_builder
APP_ENV=development
APP_SECRET_KEY=change-me
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=change-me-now
APP_CORS_ORIGINS=http://localhost,http://localhost:8080
PROVISIONING_MODE=queue
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_NAME=provisioning
REDIS_JOB_TIMEOUT_SECONDS=600
PROVISIONING_RETRY_MAX=3
PROVISIONING_RETRY_INTERVALS=10,30,60
LDAP_ENABLED=false
LDAP_SERVER_URI=ldap://ldap.example.com
LDAP_BIND_DN=cn=service,dc=example,dc=com
LDAP_BIND_PASSWORD=change-me
LDAP_BASE_DN=dc=example,dc=com
LDAP_ALLOWED_GROUPS=vm-builder-users,vm-builder-admins
PROXMOX_BASE_URL=https://proxmox.example.com:8006/api2/json
PROXMOX_TOKEN_ID=root@pam!vm-builder
PROXMOX_TOKEN_SECRET=change-me
PROXMOX_VERIFY_TLS=true
PROXMOX_ENABLED=false
PROXMOX_NODE=pve1
PROXMOX_TEMPLATE_VMID=9000
PROXMOX_TARGET_NODE=pve1
PROXMOX_STORAGE=local-lvm
PROXMOX_BRIDGE=vmbr0
PROXMOX_CLONE_MODE=full
PROXMOX_POLL_INTERVAL_SECONDS=2.0
PROXMOX_TASK_TIMEOUT_SECONDS=180
PROXMOX_TEMPLATE_DISK_GB=20
